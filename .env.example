# ════════════════════════════════════════════════════════════════
#   ВАШ АГЕНТ — пример файла окружения
#   Скопируйте этот файл в .env и заполните реальные значения.
#   Все переменные обязательны (валидация на старте — config.js).
# ════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (PostgreSQL) ───────────────────────
# R-04: имя БД — vash_agent (ASCII, без кириллицы и пробелов)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vash_agent
DB_USER=postgres
DB_PASSWORD=changeme

# ── JWT ─────────────────────────────────────────
# R-02: JWT_SECRET — обязательно (минимум 32 символа).
#       Hardcoded fallback убран — без переменной сервер не запустится.
# R-05: JWT_EXPIRES_IN — переименовано с TOKEN_EXPIRES.
JWT_SECRET=ЗАМЕНИТЕ-НА-СЛУЧАЙНЫЕ-32-ПЛЮС-СИМВОЛА-ДЛЯ-ПРОДА
JWT_EXPIRES_IN=24h

# ── CORS ────────────────────────────────────────
# R-06: список разрешённых origin (через запятую). В production
#       без ALLOWED_ORIGINS все cross-origin запросы будут отклонены.
# В development (NODE_ENV=development) CORS открыт по умолчанию.
ALLOWED_ORIGINS=https://vashagent.ru,https://www.vashagent.ru
